+    // re-translate the patched region.
+    [DllImport("libSystem.dylib", EntryPoint = "sys_icache_invalidate")]
+    private static extern void sys_icache_invalidate(nint start, nuint len);
+
     public DobbyDetour(nint originalMethodPtr, Delegate detourMethod) : base(originalMethodPtr, detourMethod) { }
 
