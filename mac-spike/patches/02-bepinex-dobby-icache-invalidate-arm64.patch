 using System;
+using System.Runtime.InteropServices;
 
 namespace BepInEx.Unity.IL2CPP.Hook.Dobby;
 
 internal class DobbyDetour : BaseNativeDetour<DobbyDetour>
 {
+    // [MAC FIX] Under Rosetta 2, Dobby's x86_64 backend patches the target code but does NOT
+    // invalidate the instruction cache (real x86 has a coherent icache, so it's a no-op there).
+    // Rosetta keeps executing the cached translation of the already-translated target and never
