{
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/join/**",
        "destination": "/join.html"
      },
      {
        "source": "/lobbies",
        "destination": "/lobbies.html"
      },
      {
        "source": "/gamemodes",
        "destination": "/gamemodes.html"
      },
      {
        "source": "/changelog",
        "destination": "/changelog.html"
      }
    ]
  }
}
